# =====================================================
# Production Environment Configuration for Hostinger VPS
# =====================================================
# Copy this file to .env.production and update the values

# =====================================================
# Database Configuration (PostgreSQL)
# =====================================================
# Get this from your Hostinger PostgreSQL database
DATABASE_URL=postgresql://username:password@localhost:5432/mawgood_production?sslmode=require

# Database name (optional, used in some scripts)
DB_NAME=mawgood_production

# =====================================================
# Redis Configuration
# =====================================================
# Use Redis for caching, queues, and real-time features
# Hostinger Redis or external Redis service
REDIS_URL=redis://:password@localhost:6379/0

# =====================================================
# CORS Configuration
# =====================================================
# Production domains - replace with your actual domains
STORE_CORS=https://your-storefront-domain.com,https://www.your-storefront-domain.com
ADMIN_CORS=https://admin.your-domain.com,https://www.admin.your-domain.com
VENDOR_CORS=https://vendor.your-domain.com,https://www.vendor.your-domain.com
AUTH_CORS=https://your-storefront-domain.com,https://admin.your-domain.com,https://vendor.your-domain.com

# =====================================================
# Security Secrets
# =====================================================
# Generate strong random strings for production
# Use: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
COOKIE_SECRET=your-super-secret-cookie-key-change-this-in-production

# =====================================================
# Email Configuration (Resend)
# =====================================================
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@your-domain.com

# =====================================================
# Payment Configuration
# =====================================================
# Using Cash On Delivery (COD) - No additional payment configuration needed

# =====================================================
# S3/Cloudinary Configuration for Image Hosting
# =====================================================
# AWS S3
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your_aws_access_key_id
S3_SECRET_ACCESS_KEY=your_aws_secret_access_key
S3_ENDPOINT=https://s3.amazonaws.com

# OR Cloudinary (alternative)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# =====================================================
# Application Settings
# =====================================================
NODE_ENV=production
PORT=9000

# =====================================================
# Optional: Third-party Services
# =====================================================
# Algolia for search (if using @mercurjs/algolia)
ALGOLIA_APP_ID=your_algolia_app_id
ALGOLIA_ADMIN_API_KEY=your_algolia_admin_key
ALGOLIA_SEARCH_API_KEY=your_algolia_search_key

# =====================================================
# SSL/TLS (if not using reverse proxy)
# =====================================================
# HTTPS_CERTIFICATE=/path/to/cert.pem
# HTTPS_KEY=/path/to/key.pem
